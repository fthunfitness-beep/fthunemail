# Admin dashboard (set to any strong password — used to sign in at /admin)
ADMIN_PASSWORD=change-me-to-something-strong

# Public
NEXT_PUBLIC_DROP_DATE=2026-07-01T00:00:00.000Z
NEXT_PUBLIC_SITE_URL=https://fthun.xyz
